<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.genius.hz</groupId>
        <artifactId>hz-admin-parent</artifactId>
        <version>1.0.0-SNAPSHOT</version>
    </parent>

    <artifactId>shared-api</artifactId>
    <name>Hazelcast Admin :: Shared API DTOs</name>
    <description>Pure Java 8 DTOs shared by backend, bridge, and external clients. NO Spring or Hazelcast deps.</description>

    <dependencies>
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-annotations</artifactId>
        </dependency>
        <!--
          Required at compile time only: Lombok's @Jacksonized generates
          @JsonDeserialize(builder = ...) annotations on the generated bytecode,
          and that annotation class lives in jackson-databind. We mark it
          'provided' so shared-api itself doesn't ship a runtime dep — backend
          and bridges already pull jackson-databind transitively (Spring Boot,
          Hazelcast).
        -->
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
            <scope>provided</scope>
        </dependency>
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <scope>provided</scope>
        </dependency>
    </dependencies>
</project>
